      <table>
        <view>
          <datasources>
            <datasource caption='sephora_clean_final_2026' name='federated.12ab24t1adc3dt1gauyoq146he0z' />
          </datasources>
          <datasource-dependencies datasource='federated.12ab24t1adc3dt1gauyoq146he0z'>
            <column aggregation='None' datatype='integer' name='[Price (classe)]' role='dimension' type='quantitative'>
              <calculation class='bin' decimals='1' formula='[price]' peg='0' size='24.6' />
            </column>
