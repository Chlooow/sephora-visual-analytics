      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.12ab24t1adc3dt1gauyoq146he0z].[ctd:id:qk]&quot;' value='Nombre de produit' />
          <alias key='&quot;[federated.12ab24t1adc3dt1gauyoq146he0z].[ctd:value_price:qk]&quot;' value='Total Value Price' />
        </aliases>
      </column>
      <column caption='decade' datatype='string' name='[Calculation_0353544297168897]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR(INT([year_founding] / 10) * 10)' />
      </column>
      <column caption='% Offre Premium &amp; Luxe' datatype='real' name='[Calculation_0921443057811456]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [price_segment] = &apos;luxury&apos; OR [price_segment] = &apos;premium&apos; THEN [id] END) &#13;&#10;/ &#13;&#10;COUNTD([id])' />
      </column>
      <column caption='NB Limited Edition' datatype='integer' name='[Calculation_1227107640299520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([limited_edition]))' />
      </column>
      <column caption='NB Exclusive' datatype='integer' name='[Calculation_1227107641475073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([exclusive]))' />
      </column>
      <column caption='NB Online Only' datatype='integer' name='[Calculation_1227107641602050]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([online_only]))' />
      </column>
      <column caption='NB Limited Time' datatype='integer' name='[Calculation_1227107641688067]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([limited_time_offer]))' />
      </column>
      <column caption='Marketing type' datatype='string' name='[Calculation_1227107641851908]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [limited_edition] THEN &quot;Limited Edition&quot;&#13;&#10;ELSEIF [exclusive] THEN &quot;Exclusive&quot;&#13;&#10;ELSEIF [limited_time_offer] THEN &quot;Offre limitée&quot;&#13;&#10;ELSEIF [online_only] THEN &quot;Online Only&quot;&#13;&#10;ELSE &quot;Standard&quot;&#13;&#10;END' />
      </column>
      <column caption='Produit sans avis' datatype='integer' name='[Calculation_1227107735158793]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [number_of_reviews] = 0 THEN [id] END)' />
      </column>
      <column caption='Emergence love' datatype='integer' name='[Calculation_1227107736088586]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [brand_status] = &quot;emerging&quot; AND [love] &gt; 1000 THEN [brand] END)' />
      </column>
      <column caption='Exclusivités bien notés' datatype='integer' name='[Calculation_1227107737985035]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [exclusive] AND [rating] &gt;= 4 THEN [id] END)' />
      </column>
      <column caption='Opportunité montée de gamme' datatype='integer' name='[Calculation_1227107739058188]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [rating] &gt;= 4.5 AND [price] &lt; 50 THEN [brand] END)' />
      </column>
      <column caption='Taux d&apos;exclusivite' datatype='real' name='[Calculation_1244699219902465]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [exclusive] = TRUE THEN [id] END) / COUNTD([id])' />
      </column>
      <column caption='% Produits bien notés' datatype='real' name='[Calculation_2242231469608960]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [rating] &gt;= 4 THEN 1 ELSE 0 END) / COUNT([id])' />
      </column>
      <column caption='Classement love' datatype='string' name='[Calculation_2242231500652545]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF RANK(SUM([love])) &lt;= 5 THEN &quot;Top 5&quot;&#13;&#10;ELSEIF RANK(SUM([love]), &apos;asc&apos;) &lt;= 5 THEN &quot;Flop 5&quot;&#13;&#10;ELSE &quot;Autres&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Marketing Flags' datatype='boolean' name='[MarketingFlags]' role='dimension' type='nominal' />
      <column aggregation='None' datatype='integer' name='[Price (classe)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='1' formula='[price]' peg='0' size='24.6' />
      </column>
      <column aggregation='None' datatype='integer' name='[Rating (classe)]' role='dimension' type='quantitative'>
